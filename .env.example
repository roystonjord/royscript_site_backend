# ---- App ----
NODE_ENV=production
HOST=127.0.0.1
PORT=3000

# Comma-separated allowed origins. Only needed if the form is served from a
# DIFFERENT origin than this API. If the form posts to /api/contact on the same
# domain (recommended), you can leave this empty.
ALLOWED_ORIGIN=https://www.royscript.com,https://royscript.com

# ---- Postgres (on the host machine) ----
# With `docker run --network host`, the container shares the host network,
# so 127.0.0.1 reaches your host Postgres directly.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=royscript_site
DB_USER=royscript_app
DB_PASSWORD=change_me_to_a_strong_password
